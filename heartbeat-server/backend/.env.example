PORT=3002
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/heartbeat_monitor
DB_CONNECT_ATTEMPTS=3
DB_CONNECT_RETRY_MS=2000
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300
LOG_RETENTION_LIMIT=200
ALERT_RETENTION_LIMIT=50
METRIC_RETENTION_LIMIT=1000
LOG_TTL_SECONDS=604800
METRIC_TTL_SECONDS=2592000
METRICS_QUERY_LIMIT=500
INCIDENT_COOLDOWN_SECONDS=5
SOCKET_RATE_LIMIT_WINDOW_MS=10000
SOCKET_RATE_LIMIT_MAX=30
SOCKET_INVALID_PAYLOAD_LIMIT=3
DOCKER_MONITOR_ENABLED=true
DOCKER_MONITOR_INTERVAL_MS=5000
DOCKER_MONITOR_CLUSTER=local-docker
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=replace-with-another-long-random-secret
REFRESH_TOKEN_EXPIRES_IN=7d
ACCESS_TOKEN_COOKIE_NAME=heartbeat_access
REFRESH_TOKEN_COOKIE_NAME=heartbeat_refresh
COOKIE_SECURE=false
COOKIE_SAMESITE=strict
LOG_LEVEL=info
APP_VERSION=1.0.0
EXPORT_LIMIT_MAX=500
ENABLE_OUTBOUND_NOTIFICATIONS=true
SLACK_WEBHOOK_URL=
GENERIC_WEBHOOK_URL=
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=admin12345
BOOTSTRAP_ADMIN_ROLE=ADMIN
